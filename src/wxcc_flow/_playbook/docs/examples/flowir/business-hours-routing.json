{
  "name": "Example_Business_Hours_Routing",
  "flowType": "FLOW",
  "description": "Business hours routing: check schedule → working hours path vs closed path. Demonstrates business-hours activity with multi-port edges and set-variable double declaration pattern.",
  "variables": [
    {"name": "flowStatus", "type": "STRING", "defaultValue": "open", "isInput": false, "isOutput": false, "reportable": false}
  ],
  "nodes": [
    {
      "id": "start",
      "name": "NewPhoneContact",
      "activityType": "start",
      "group": "action",
      "properties": {"activityName": "start"}
    },
    {
      "id": "biz-hours",
      "name": "CheckBusinessHours",
      "activityType": "enum-gateway",
      "group": "enum-gateway",
      "properties": {
        "activityName": "business-hours",
        "businessHoursId": "00000000-0000-0000-0000-000000000000",
        "businessHoursId:name": "Default Schedule",
        "businessHoursId_name": "Default Schedule"
      }
    },
    {
      "id": "set-open",
      "name": "SetStatusOpen",
      "activityType": "action",
      "group": "set-variable",
      "properties": {
        "activityName": "set-variable",
        "variable_1": "flowStatus",
        "value_1": "open",
        "type_1": "String",
        "setVariablesArray": [
          {"variable": "flowStatus", "value": "open"}
        ]
      }
    },
    {
      "id": "welcome",
      "name": "WelcomeMessage",
      "activityType": "action",
      "group": "action",
      "properties": {
        "activityName": "play-message",
        "toggle": true,
        "promptsTts": [{"name": "Thank you for calling during business hours. An agent will be with you shortly.", "type": "tts", "value": "Thank you for calling during business hours. An agent will be with you shortly."}],
        "connector": "Cisco Cloud Text-to-Speech",
        "connector_name": "Cisco Cloud Text-to-Speech",
        "connector:name": "Cisco Cloud Text-to-Speech",
        "connector_type": "Cisco Cloud Text-to-Speech",
        "connector:type": "Cisco Cloud Text-to-Speech",
        "speakingRate": 1,
        "volumeGainDb": 0
      }
    },
    {
      "id": "queue",
      "name": "MainQueue",
      "activityType": "action",
      "group": "action",
      "properties": {
        "activityName": "queue-contact",
        "queueId": "247ec630-c684-4a6b-8b05-7c9cfcdb8f36"
      }
    },
    {
      "id": "hold-music",
      "name": "HoldMusic",
      "activityType": "action",
      "group": "action",
      "properties": {
        "activityName": "play-music",
        "musicFile": "defaultmusic_on_hold.wav",
        "musicDuration": "600"
      }
    },
    {
      "id": "closed-msg",
      "name": "ClosedMessage",
      "activityType": "action",
      "group": "action",
      "properties": {
        "activityName": "play-message",
        "toggle": true,
        "promptsTts": [{"name": "We are currently closed. Our business hours are Monday through Friday, 8 AM to 5 PM. Please call back during business hours.", "type": "tts", "value": "We are currently closed. Our business hours are Monday through Friday, 8 AM to 5 PM. Please call back during business hours."}],
        "connector": "Cisco Cloud Text-to-Speech",
        "connector_name": "Cisco Cloud Text-to-Speech",
        "connector:name": "Cisco Cloud Text-to-Speech",
        "connector_type": "Cisco Cloud Text-to-Speech",
        "connector:type": "Cisco Cloud Text-to-Speech",
        "speakingRate": 1,
        "volumeGainDb": 0
      }
    },
    {
      "id": "disconnect",
      "name": "Disconnect",
      "activityType": "action",
      "group": "terminating-action",
      "properties": {"activityName": "disconnect-contact"}
    },
    {
      "id": "err-msg",
      "name": "ErrorMessage",
      "activityType": "action",
      "group": "action",
      "properties": {
        "activityName": "play-message",
        "toggle": true,
        "promptsTts": [{"name": "We are experiencing technical difficulties.", "type": "tts", "value": "We are experiencing technical difficulties."}],
        "connector": "Cisco Cloud Text-to-Speech",
        "connector_name": "Cisco Cloud Text-to-Speech",
        "connector:name": "Cisco Cloud Text-to-Speech",
        "connector_type": "Cisco Cloud Text-to-Speech",
        "connector:type": "Cisco Cloud Text-to-Speech",
        "speakingRate": 1,
        "volumeGainDb": 0
      }
    },
    {
      "id": "err-disconnect",
      "name": "ErrorDisconnect",
      "activityType": "action",
      "group": "terminating-action",
      "properties": {"activityName": "disconnect-contact"}
    }
  ],
  "edges": [
    {"id": "e1", "from": "start", "to": "biz-hours"},
    {"id": "e2", "from": "biz-hours", "to": "set-open", "condition": "workingHours"},
    {"id": "e3", "from": "biz-hours", "to": "closed-msg", "condition": "holidays"},
    {"id": "e4", "from": "biz-hours", "to": "closed-msg", "condition": "default"},
    {"id": "e5", "from": "set-open", "to": "welcome", "condition": "out"},
    {"id": "e6", "from": "welcome", "to": "queue", "condition": "default"},
    {"id": "e7", "from": "queue", "to": "hold-music"},
    {"id": "e8", "from": "hold-music", "to": "disconnect", "condition": "default"},
    {"id": "e9", "from": "closed-msg", "to": "disconnect", "condition": "default"},
    {"id": "e10", "from": "err-msg", "to": "err-disconnect", "condition": "default"}
  ],
  "eventFlows": {
    "OnGlobalError": {
      "eventSpecificationName": "GlobalErrorHandling",
      "nodes": [
        {"id": "event-error", "name": "OnGlobalError", "activityType": "action", "group": "action", "properties": {"activityName": "Event", "eventSourceName": "OnGlobalError", "eventClassificationName": "ErrorHandling", "eventSpecificationName": "GlobalErrorHandling"}}
      ],
      "edges": [
        {"id": "ev1", "from": "event-error", "to": "err-msg"}
      ]
    }
  }
}
