{
  "name": "Example_Data_Dip_Routing",
  "flowType": "FLOW",
  "description": "HTTP data dip with conditional routing: collect account number → HTTP lookup → branch on result → route to VIP or standard queue. Demonstrates http-request-v2, set-variable, condition-activity, and ivr-collectdigits.",
  "variables": [
    {"name": "accountNumber", "type": "STRING", "defaultValue": "", "isInput": false, "isOutput": false, "reportable": false},
    {"name": "customerTier", "type": "STRING", "defaultValue": "standard", "isInput": false, "isOutput": false, "reportable": false},
    {"name": "httpStatusCode", "type": "INTEGER", "defaultValue": "0", "isInput": false, "isOutput": false, "reportable": false}
  ],
  "nodes": [
    {
      "id": "start",
      "name": "NewPhoneContact",
      "activityType": "start",
      "group": "action",
      "properties": {"activityName": "start"}
    },
    {
      "id": "collect",
      "name": "CollectAccount",
      "activityType": "action",
      "group": "action",
      "properties": {
        "activityName": "ivr-collectdigits",
        "toggle": true,
        "promptsTts": [{"name": "Please enter your account number followed by the pound key.", "type": "tts", "value": "Please enter your account number followed by the pound key."}],
        "connector": "Cisco Cloud Text-to-Speech",
        "connector_name": "Cisco Cloud Text-to-Speech",
        "connector:name": "Cisco Cloud Text-to-Speech",
        "connector_type": "Cisco Cloud Text-to-Speech",
        "connector:type": "Cisco Cloud Text-to-Speech",
        "entryTimeout": "5",
        "interDigitTimeout": "3",
        "minDigits": 1,
        "maxDigits": 10,
        "terminatorSymbol": "#",
        "speakingRate": 1,
        "volumeGainDb": 0
      }
    },
    {
      "id": "set-account",
      "name": "SetAccountNumber",
      "activityType": "action",
      "group": "set-variable",
      "properties": {
        "activityName": "set-variable",
        "variable_1": "accountNumber",
        "value_1": "{{CollectAccount.DigitsEntered}}",
        "type_1": "String",
        "setVariablesArray": [
          {"variable": "accountNumber", "value": "{{CollectAccount.DigitsEntered}}"}
        ]
      }
    },
    {
      "id": "http-lookup",
      "name": "LookupCustomer",
      "activityType": "action",
      "group": "http-request",
      "properties": {
        "activityName": "http-request-v2",
        "requestUrl": "https://api.example.com/customers/{{accountNumber}}",
        "requestMethod": "GET",
        "contentType": "application/json",
        "requestTimeout": "5000",
        "retryOn5xx": true,
        "maxRetries": "1",
        "outputVariableArray": [
          {"outputVariable": "customerTier", "jsonPathExp": "$.tier"},
          {"outputVariable": "httpStatusCode", "jsonPathExp": "$.statusCode"}
        ]
      }
    },
    {
      "id": "check-tier",
      "name": "IsVIP",
      "activityType": "enum-gateway",
      "group": "enum-gateway",
      "properties": {
        "activityName": "condition-activity",
        "expression": "{{customerTier == vip}}"
      }
    },
    {
      "id": "vip-msg",
      "name": "VIPMessage",
      "activityType": "action",
      "group": "action",
      "properties": {
        "activityName": "play-message",
        "toggle": true,
        "promptsTts": [{"name": "Welcome back, valued customer. We are connecting you to a priority agent.", "type": "tts", "value": "Welcome back, valued customer. We are connecting you to a priority agent."}],
        "connector": "Cisco Cloud Text-to-Speech",
        "connector_name": "Cisco Cloud Text-to-Speech",
        "connector:name": "Cisco Cloud Text-to-Speech",
        "connector_type": "Cisco Cloud Text-to-Speech",
        "connector:type": "Cisco Cloud Text-to-Speech",
        "speakingRate": 1,
        "volumeGainDb": 0
      }
    },
    {
      "id": "queue-vip",
      "name": "VIPQueue",
      "activityType": "action",
      "group": "action",
      "properties": {
        "activityName": "queue-contact",
        "queueId": "247ec630-c684-4a6b-8b05-7c9cfcdb8f36"
      }
    },
    {
      "id": "queue-standard",
      "name": "StandardQueue",
      "activityType": "action",
      "group": "action",
      "properties": {
        "activityName": "queue-contact",
        "queueId": "b4a320d4-bf38-4468-b652-d505190c0f34"
      }
    },
    {
      "id": "hold-music",
      "name": "HoldMusic",
      "activityType": "action",
      "group": "action",
      "properties": {
        "activityName": "play-music",
        "musicFile": "defaultmusic_on_hold.wav",
        "musicDuration": "600"
      }
    },
    {
      "id": "disconnect",
      "name": "Disconnect",
      "activityType": "action",
      "group": "terminating-action",
      "properties": {"activityName": "disconnect-contact"}
    },
    {
      "id": "err-msg",
      "name": "ErrorMessage",
      "activityType": "action",
      "group": "action",
      "properties": {
        "activityName": "play-message",
        "toggle": true,
        "promptsTts": [{"name": "We are experiencing technical difficulties.", "type": "tts", "value": "We are experiencing technical difficulties."}],
        "connector": "Cisco Cloud Text-to-Speech",
        "connector_name": "Cisco Cloud Text-to-Speech",
        "connector:name": "Cisco Cloud Text-to-Speech",
        "connector_type": "Cisco Cloud Text-to-Speech",
        "connector:type": "Cisco Cloud Text-to-Speech",
        "speakingRate": 1,
        "volumeGainDb": 0
      }
    },
    {
      "id": "err-disconnect",
      "name": "ErrorDisconnect",
      "activityType": "action",
      "group": "terminating-action",
      "properties": {"activityName": "disconnect-contact"}
    }
  ],
  "edges": [
    {"id": "e1", "from": "start", "to": "collect"},
    {"id": "e2", "from": "collect", "to": "set-account", "condition": "default"},
    {"id": "e3", "from": "collect", "to": "queue-standard", "condition": "timeout"},
    {"id": "e4", "from": "set-account", "to": "http-lookup", "condition": "out"},
    {"id": "e5", "from": "http-lookup", "to": "check-tier", "condition": "default"},
    {"id": "e6", "from": "check-tier", "to": "vip-msg", "condition": "true"},
    {"id": "e7", "from": "check-tier", "to": "queue-standard", "condition": "false"},
    {"id": "e8", "from": "vip-msg", "to": "queue-vip", "condition": "default"},
    {"id": "e9", "from": "queue-vip", "to": "hold-music"},
    {"id": "e10", "from": "queue-standard", "to": "hold-music"},
    {"id": "e11", "from": "hold-music", "to": "disconnect", "condition": "default"},
    {"id": "e12", "from": "err-msg", "to": "err-disconnect", "condition": "default"}
  ],
  "eventFlows": {
    "OnGlobalError": {
      "eventSpecificationName": "GlobalErrorHandling",
      "nodes": [
        {"id": "event-error", "name": "OnGlobalError", "activityType": "action", "group": "action", "properties": {"activityName": "Event", "eventSourceName": "OnGlobalError", "eventClassificationName": "ErrorHandling", "eventSpecificationName": "GlobalErrorHandling"}}
      ],
      "edges": [
        {"id": "ev1", "from": "event-error", "to": "err-msg"}
      ]
    }
  }
}
